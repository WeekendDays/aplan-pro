NODE_ENV=production
PORT=8080
HOST=127.0.0.1
DATA_DIR=/var/lib/stock-portfolio
COOKIE_SECURE=true
STOCK_APP_USERNAME=operator
STOCK_APP_PASSWORD=change-this-password
SESSION_TTL_DAYS=30
SESSION_SECRET=replace-with-at-least-32-random-characters
QUOTE_REFRESH_TIMEOUT_MS=10000
